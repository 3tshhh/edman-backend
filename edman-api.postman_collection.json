        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.otpSessionToken) {",
                  "  pm.collectionVariables.set('otpSessionToken', res.data.otpSessionToken);",
                  "  console.log('otpSessionToken saved');",
                  "}",
                  "pm.test('Login returns otpSessionToken', function () {",
                  "  pm.expect(res.statusCode).to.eql(201);",
                  "  pm.expect(res.data).to.have.property('otpSessionToken');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
